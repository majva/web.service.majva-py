Generic single-database configuration.

Environment:
    POSTGRES_CONNECTION_STRING  Database connection string (required for migrate/upgrade)

Commands:

    # Apply all pending migrations (used by CI/CD and Docker entrypoint)
    python src/infrastructure/scripts/run_migrations.py --upgrade

    # Generate a migration from model changes, then apply it (local development)
    python src/infrastructure/scripts/run_migrations.py --sync -m "describe your change"

    # Generate only (without applying)
    python src/infrastructure/scripts/run_migrations.py --autogenerate -m "describe your change"

    # Roll back one revision
    cd src/infrastructure && python -m alembic downgrade -1